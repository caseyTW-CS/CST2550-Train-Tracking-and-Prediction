@page
@model TrainApp.Pages.DeparturesModel
@{
    ViewData["Title"] = "Departures";
}

<style>
    body {
        background-color: #a8d4e8;
    }

    .departures-title {
        font-family: 'Dancing Script', cursive;
        font-size: 2.2rem;
        color: #1a2f5a;
    }

    .section-title {
        font-family: 'Dancing Script', cursive;
        font-size: 1.8rem;
        color: #1a2f5a;
    }

    .table {
        background: #0b1e3c;
        color: #fff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 6px 20px rgba(0,0,0,0.15);
    }

    .table th {
        background: #111;
        color: #00e5ff;
        text-transform: uppercase;
        font-size: 0.8rem;
    }

    .table tr:hover {
        background: rgba(0,229,255,0.08);
    }

    .table tbody tr:first-child {
        background: rgba(0,255,140,0.15);
        font-weight: 600;
    }

    .due {
        color: #00ffcc;
        font-weight: bold;
        animation: pulse 1s infinite;
    }

    @@keyframes pulse {
        50% { opacity: 0.4; }
    }
</style>

<h2 class="text-center departures-title mb-2">Departures & Arrivals</h2>
<p class="text-center text-muted mb-4">Check upcoming trains at any Elizabeth Line station</p>

<form method="post">
    <div class="input-group mb-3">
        <input type="text" class="form-control" name="stationName" placeholder="Enter station (e.g. Paddington)" />
        <button class="btn btn-primary">Search</button>
    </div>
</form>

<p class="text-center mb-4" style="font-size: 0.85rem; color: #d9534f; font-weight: 600;">
    ⚠️ Some stations may not return live data due to TfL API limitations.
</p>

@if (Model.searchedStation != null)
{
    <div class="alert alert-info text-center">
        Trains for <strong>@Model.searchedStation</strong>
    </div>

    <!-- ALWAYS SHOW TABLE NOW -->
    <h3 class="text-center section-title mt-4 mb-3">Live Trains</h3>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Destination</th>
                <th>Time</th>
                <th>Platform</th>
            </tr>
        </thead>
        <tbody id="departuresBody">
            <!-- JS fills this -->
        </tbody>
    </table>
}

@section Scripts {
<script>
    let currentStation = "@Model.searchedStation";

    async function refreshData() {
        if (!currentStation) return;

        const res = await fetch(`?handler=Data&station=${currentStation}`);
        const data = await res.json();

        const table = document.getElementById("departuresBody");
        if (!table) return;

        table.innerHTML = "";

        if (data.length === 0) {
            table.innerHTML = `
                <tr>
                    <td colspan="3" style="text-align:center; color:#ff6b6b;">
                        No trains found
                    </td>
                </tr>
            `;
            return;
        }

        data.forEach(train => {
            const isDue = train.departureTime === "Due";

            table.innerHTML += `
                <tr>
                    <td>${train.destination}</td>
                    <td class="${isDue ? "due" : ""}">${train.departureTime}</td>
                    <td><span class="badge bg-dark">${train.platform}</span></td>
                </tr>
            `;
        });
    }

    // run immediately after search
    refreshData();

    // auto refresh like real boards
    setInterval(refreshData, 15000);
</script>
}