<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Where's the Train?</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&display=swap" rel="stylesheet" />
</head>

<body>
<header>
    <nav class="navbar navbar-expand-sm box-shadow mb-3">
        <div class="container-fluid px-4 d-flex align-items-center">

            <!-- LOGO -->
            <a class="navbar-brand" asp-page="/Index">Where's the Train?</a>

            <!-- MOBILE BUTTON -->
            <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse">

                <!-- RIGHT SIDE -->
                <div class="ms-auto d-flex align-items-center gap-3">

                    <!-- 🚦 SERVICE STATUS -->
                    <span id="serviceStatus" style="font-weight:500;">
                        ● Loading...
                    </span>

                    <!-- ⭐ FAVOURITES DROPDOWN -->
                    <div class="dropdown">
                        <button id="favBtn" class="btn btn-link p-0 border-0" title="Favourites"
                                style="font-size:20px; text-decoration:none; line-height:1;"
                                data-bs-toggle="dropdown" aria-expanded="false">
                            ⭐
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow" id="favDropdown" style="min-width:220px;">
                            <li><h6 class="dropdown-header">⭐ Favourite Stations</h6></li>
                            <li><div id="favList"><div class="dropdown-item text-muted" style="font-size:13px;">Loading...</div></div></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/Account#favourites" style="font-size:13px;">Manage favourites →</a></li>
                        </ul>
                    </div>

                    <!-- 👤 USER / LOGIN -->
                    @if (Context.Session.GetString("UserName") != null)
                    {
                        <span class="text-white">
                            Hello @Context.Session.GetString("UserName")
                        </span>

                        <a asp-page="/Account" title="My Account" style="text-decoration:none; font-size: 26px;">
                            &#128100;
                        </a>

                        <a asp-page="/Logout" class="btn btn-outline-danger btn-sm">
                            Logout
                        </a>
                    }
                    else
                    {
                        <a asp-page="/Login" title="Login" style="text-decoration:none; font-size: 26px;">
                            &#128100;
                        </a>
                    }

@if (Context.Session.GetString("UserName") != null)
{
    <span style="position: relative;">
        <a asp-page="/Alerts" id="alertBell" style="font-size:20px;">🔔</a>

        <span id="alertBadge" style="
            position:absolute;
            top:-6px;
            right:-10px;
            background:red;
            color:white;
            font-size:10px;
            border-radius:50%;
            padding:2px 6px;
            display:@((ViewBag.AlertCount > 0) ? "inline-block" : "none");
        ">
            @ViewBag.AlertCount
        </span>
    </span>
}

                </div>

            </div>
        </div>
    </nav>
</header>

<!-- MAIN CONTENT -->
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<!-- FOOTER -->
<footer class="footer text-muted" style="display: flex; align-items: flex-end; padding-bottom: 8px;">
    <div class="container text-center border-top pt-2">
        &copy; 2026 - Where's the Train?<br> All Rights Reserved
    </div>
</footer>

<!-- SCRIPTS -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

<!-- 🚦 LIVE SERVICE STATUS -->
<script>
fetch("https://api.tfl.gov.uk/Line/elizabeth/Status")
.then(res => res.json())
.then(data => {
    const status = data[0].lineStatuses[0].statusSeverityDescription;
    const el = document.getElementById("serviceStatus");

    if (status.includes("Good")) {
        el.innerHTML = "● Good Service";
        el.style.color = "green";
    }
    else if (status.includes("Minor")) {
        el.innerHTML = "● Minor Delays";
        el.style.color = "orange";
    }
    else {
        el.innerHTML = "● Delays";
        el.style.color = "red";
    }
})
.catch(() => {
    document.getElementById("serviceStatus").innerHTML = "● Unknown";
});
</script>

<script>
let lastAlertCount = 0;

async function refreshAlertsGlobal() {

    const badge = document.getElementById("alertBadge");
    const bell = document.getElementById("alertBell");

    // If alerts were cleared → hide badge and STOP
    if (sessionStorage.getItem("alertsCleared") === "true") {
        if (badge) badge.style.display = "none";
        return;
    }

    try {
        const res = await fetch('/Alerts?handler=GetActiveAlerts');
        const data = await res.json();

        if (!data.success) return;

        if (badge) {
            // update number
            badge.innerText = data.alertCount;

            // show/hide badge
            badge.style.display = data.alertCount > 0 ? "inline-block" : "none";

            // 🔔 animate bell if new alerts appear
            if (data.alertCount > lastAlertCount && bell) {
                bell.classList.add("bell-animate");

                setTimeout(() => {
                    bell.classList.remove("bell-animate");
                }, 600);
            }

            lastAlertCount = data.alertCount;
        }

    } catch {
        console.log("alert badge failed");
    }
}

// 🚀 run immediately + every 15s
refreshAlertsGlobal();
setInterval(refreshAlertsGlobal, 15000);
</script>

<!-- ⭐ FAVOURITES DROPDOWN -->
<script>
document.getElementById('favBtn').addEventListener('show.bs.dropdown', function () {
    fetch('/Account?handler=Favourites')
        .then(res => res.json())
        .then(data => {
            const list = document.getElementById('favList');

            if (!data.loggedIn) {
                list.innerHTML = '<a class="dropdown-item text-muted" href="/Login" style="font-size:13px;">Log in to see favourites</a>';
                return;
            }

            if (!data.stations || data.stations.length === 0) {
                list.innerHTML = '<div class="dropdown-item text-muted" style="font-size:13px;">No favourites yet — add them on your account page.</div>';
                return;
            }

            list.innerHTML = data.stations.map(s =>
                `<li><a class="dropdown-item" href="/Departures?stationName=${encodeURIComponent(s)}" style="font-size:13px;">🚉 ${s}</a></li>`
            ).join('');
        })
        .catch(() => {
            document.getElementById('favList').innerHTML = '<div class="dropdown-item text-muted" style="font-size:13px;">Could not load favourites.</div>';
        });
});
</script>

@RenderSection("Scripts", required: false)

</body>
</html>