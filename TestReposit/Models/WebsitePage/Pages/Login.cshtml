@page
@model TestReposit.Models.WebsitePage.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<style>
    /* main wrapper for the two panels */
    .login-wrapper {
        display: flex;
        height: 80vh;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        max-width: 900px;
        margin: 0 auto;
    }

    /* left navy blue panel */
    .login-left {
        background-color: #4B4E6D;
        color: white;
        width: 40%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 40px;
        text-align: center;
    }

    /* right white panel */
    .login-right {
        background-color: white;
        width: 60%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 40px;
    }

    /* arrow button to switch between login and register */
    .toggle-btn {
        background: none;
        border: 2px solid white;
        color: white;
        padding: 10px 30px;
        border-radius: 25px;
        cursor: pointer;
        margin-top: 20px;
        font-size: 14px;
        letter-spacing: 1px;
    }

    .toggle-btn:hover {
        background-color: white;
        color: #4B4E6D;
    }

    /* input fields with a light blue tint */
    .form-control {
        background-color: #f0f4fa;
        border: none;
        padding: 12px;
        margin-bottom: 12px;
    }

    /* navy blue heading on the right panel */
    .form-title {
        color: #4B4E6D;
        text-align: center;
        margin-bottom: 1.5rem;
    }

    /* submit button */
    .submit-btn {
        background-color: #4B4E6D;
        color: white;
        border: none;
        padding: 12px;
        border-radius: 25px;
        width: 100%;
        font-size: 16px;
        letter-spacing: 1px;
        margin-top: 10px;
        cursor: pointer;
    }

    /* hover turns mint green to contrast with navy */
    .submit-btn:hover {
        background-color: #84DCC6;
        color: #4B4E6D;
    }
</style>

<div class="login-wrapper">

    <!-- left navy panel - changes text based on which form is showing -->
    <div class="login-left" id="leftPanel">
        <h2 id="leftTitle">Welcome Back!</h2>
        <p id="leftText">To keep connected with us please login with your personal info</p>
        <!-- arrow button to switch between login and register -->
        <button class="toggle-btn" onclick="toggleForm()">&#8595; SIGN UP</button>
    </div>

    <!-- right white panel - shows login or register form -->
    <div class="login-right">

        <!-- login form - shows by default -->
        <div id="loginForm">
            <h2 class="form-title">Sign In</h2>
            <input type="text" class="form-control" placeholder="&#128100; Username" />
            <input type="password" class="form-control" placeholder="&#128274; Password" />
            <button class="submit-btn">SIGN IN</button>
        </div>

        <!-- register form - hidden by default -->
        <div id="registerForm" style="display: none;">
            <h2 class="form-title">Create Account</h2>
            <input type="text" class="form-control" placeholder="&#128100; Username" />
            <input type="email" class="form-control" placeholder="&#9993; Email" />
            <input type="number" class="form-control" placeholder="&#128100; Age" />
            <input type="tel" class="form-control" placeholder="&#128222; Phone" />
            <input type="password" class="form-control" placeholder="&#128274; Password" />
            <button class="submit-btn">SIGN UP</button>
        </div>

    </div>
</div>

<script>
    // tracks which form is currently showing
    let showingLogin = true;

    // switches between login and register when the arrow button is clicked
    function toggleForm() {
        showingLogin = !showingLogin;
        let loginForm = document.getElementById('loginForm');
        let registerForm = document.getElementById('registerForm');
        let leftTitle = document.getElementById('leftTitle');
        let leftText = document.getElementById('leftText');
        let toggleBtn = document.querySelector('.toggle-btn');

        if (showingLogin) {
            // switch back to login form
            loginForm.style.display = 'block';
            registerForm.style.display = 'none';
            leftTitle.innerText = 'Welcome Back!';
            leftText.innerText = 'To keep connected with us please login with your personal info';
            toggleBtn.innerHTML = '&#8595; SIGN UP';
        } else {
            // switch to register form
            loginForm.style.display = 'none';
            registerForm.style.display = 'block';
            leftTitle.innerText = 'Hello!';
            leftText.innerText = 'Enter your details and start your journey with us';
            toggleBtn.innerHTML = '&#8593; SIGN IN';
        }
    }
</script>
