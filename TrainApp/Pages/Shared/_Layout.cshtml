<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Where's the Train?</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&display=swap" rel="stylesheet" />

    <style>
        /* ── DARK MODE ── */
        body.dark-mode {
            background-color: #0f1b2d !important;
            color: #c9d8f0 !important;
        }
        body.dark-mode .navbar {
            background-color: #1a2a42 !important;
        }
        body.dark-mode .navbar-brand,
        body.dark-mode .hero-title {
            color: #a8c4e8 !important;
        }
        body.dark-mode .hero-subtitle,
        body.dark-mode .status-sub,
        body.dark-mode .card-text,
        body.dark-mode .roller-label,
        body.dark-mode .weather-city,
        body.dark-mode .weather-desc {
            color: #7a9bc4 !important;
        }
        body.dark-mode .info-card,
        body.dark-mode .weather-widget,
        body.dark-mode .card,
        body.dark-mode .train-card,
        body.dark-mode .journey-card,
        body.dark-mode .detail-card {
            background-color: #1a2a42 !important;
            border-color: #2a3f5f !important;
            color: #c9d8f0 !important;
        }
        body.dark-mode .form-control {
            background-color: #1a2a42 !important;
            border-color: #2a3f5f !important;
            color: #c9d8f0 !important;
        }
        body.dark-mode .form-control::placeholder {
            color: #4a6a8a !important;
        }
        body.dark-mode .roller {
            background-color: #1a2a42 !important;
            border-color: #2a3f5f !important;
        }
        body.dark-mode .roller-overlay-top {
            background: linear-gradient(to bottom, #1a2a42, transparent) !important;
        }
        body.dark-mode .roller-overlay-bot {
            background: linear-gradient(to top, #1a2a42, transparent) !important;
        }
        body.dark-mode .roller-item { color: #4a6a8a !important; }
        body.dark-mode .roller-item.selected { color: #a8c4e8 !important; }
        body.dark-mode .roller-highlight { border-color: #2a3f5f !important; }
        body.dark-mode .suggestion-dropdown {
            background-color: #1a2a42 !important;
            border-color: #2a3f5f !important;
        }
        body.dark-mode .suggestion-item {
            color: #c9d8f0 !important;
            border-bottom-color: #2a3f5f !important;
        }
        body.dark-mode .suggestion-item:hover { background: #243650 !important; }
        body.dark-mode .card-title,
        body.dark-mode .status-text,
        body.dark-mode .train-dest,
        body.dark-mode .journey-time,
        body.dark-mode .detail-value,
        body.dark-mode .stat-value {
            color: #a8c4e8 !important;
        }
        body.dark-mode .card-btn,
        body.dark-mode .action-btn.active,
        body.dark-mode .map-btn {
            background-color: #243650 !important;
            border-color: #2a3f5f !important;
        }
        body.dark-mode .home-leave-btn {
            background: #1a2a42 !important;
            border-color: #2a3f5f !important;
            color: #a8c4e8 !important;
        }
        body.dark-mode .home-leave-btn.active,
        body.dark-mode .leave-option-btn.active,
        body.dark-mode .ampm-btn.active {
            background: #3a5a8a !important;
            border-color: #3a5a8a !important;
            color: white !important;
        }
        body.dark-mode .ampm-btn {
            background: #1a2a42 !important;
            border-color: #2a3f5f !important;
            color: #7a9bc4 !important;
        }
        body.dark-mode .route-header { background: #1a2a42 !important; }
        body.dark-mode .stat-box { background: #243650 !important; }
        body.dark-mode .stop-name { color: #a8c4e8 !important; }
        body.dark-mode .footer { color: #4a6a8a !important; }
        body.dark-mode .dropdown-menu {
            background-color: #1a2a42 !important;
            border-color: #2a3f5f !important;
        }
        body.dark-mode .dropdown-item { color: #c9d8f0 !important; }
        body.dark-mode .dropdown-item:hover { background-color: #243650 !important; }

        /* ── TOGGLE BUTTON ── */
        .theme-toggle {
            background: none;
            border: none;
            font-size: 20px;
            cursor: pointer;
            padding: 0;
            line-height: 1;
            transition: transform 0.3s ease;
        }
        .theme-toggle:hover { transform: rotate(20deg); }
    </style>
</head>

<body>
<header>
    <nav class="navbar navbar-expand-sm box-shadow mb-3">
        <div class="container-fluid px-4 d-flex align-items-center">

            <!-- LOGO -->
            <a class="navbar-brand" asp-page="/Index">Where's the Train?</a>

            <!-- MOBILE BUTTON -->
            <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse">

                <!-- RIGHT SIDE -->
                <div class="ms-auto d-flex align-items-center gap-3">

                    <!-- SERVICE STATUS -->
                    <span id="serviceStatus" style="font-weight:500;">
                        ● Loading...
                    </span>

                    <!-- DARK MODE TOGGLE -->
                    <button class="theme-toggle" id="themeToggle" title="Toggle dark mode">🌙</button>

                    <!-- FAVOURITES DROPDOWN -->
                    <div class="dropdown">
                        <button id="favBtn" class="btn btn-link p-0 border-0" title="Favourites"
                                style="font-size:20px; text-decoration:none; line-height:1;"
                                data-bs-toggle="dropdown" aria-expanded="false">
                            ⭐
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow" id="favDropdown" style="min-width:220px;">
                            <li><h6 class="dropdown-header">⭐ Favourite Stations</h6></li>
                            <li><div id="favList"><div class="dropdown-item text-muted" style="font-size:13px;">Loading...</div></div></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/Account#favourites" style="font-size:13px;">Manage favourites →</a></li>
                        </ul>
                    </div>

                    <!-- USER / LOGIN -->
                    @if (Context.Session.GetString("UserName") != null)
                    {
                        <span class="text-white">
                            Hello @Context.Session.GetString("UserName")
                        </span>

                        <a asp-page="/Account" title="My Account" style="text-decoration:none; font-size: 26px;">
                            &#128100;
                        </a>

                        <a asp-page="/Logout" class="btn btn-outline-danger btn-sm">
                            Logout
                        </a>
                    }
                    else
                    {
                        <a asp-page="/Login" title="Login" style="text-decoration:none; font-size: 26px;">
                            &#128100;
                        </a>
                    }

                    @if (Context.Session.GetString("UserName") != null)
                    {
                        <span style="position: relative;">
                            <a asp-page="/Alerts" id="alertBell" style="font-size:20px;">🔔</a>
                            <span id="alertBadge" style="
                                position:absolute;
                                top:-6px;
                                right:-10px;
                                background:red;
                                color:white;
                                font-size:10px;
                                border-radius:50%;
                                padding:2px 6px;
                                display:@((ViewBag.AlertCount > 0) ? "inline-block" : "none");
                            ">
                                @ViewBag.AlertCount
                            </span>
                        </span>
                    }

                </div>
            </div>
        </div>
    </nav>
</header>

<!-- MAIN CONTENT -->
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<!-- FOOTER -->
<footer class="footer text-muted" style="display: flex; align-items: flex-end; padding-bottom: 8px;">
    <div class="container text-center border-top pt-2">
        &copy; 2026 - Where's the Train?<br> All Rights Reserved
    </div>
</footer>

<!-- SCRIPTS -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

<!-- DARK MODE -->
<script>
    const toggle = document.getElementById('themeToggle');
    const saved = localStorage.getItem('theme');
    if (saved === 'dark') {
        document.body.classList.add('dark-mode');
        toggle.textContent = '☀️';
    }
    toggle.addEventListener('click', () => {
        const isDark = document.body.classList.toggle('dark-mode');
        toggle.textContent = isDark ? '☀️' : '🌙';
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
</script>

<!-- LIVE SERVICE STATUS -->
<script>
fetch("https://api.tfl.gov.uk/Line/elizabeth/Status")
.then(res => res.json())
.then(data => {
    const status = data[0].lineStatuses[0].statusSeverityDescription;
    const el = document.getElementById("serviceStatus");
    if (status.includes("Good")) { el.innerHTML = "● Good Service"; el.style.color = "green"; }
    else if (status.includes("Minor")) { el.innerHTML = "● Minor Delays"; el.style.color = "orange"; }
    else { el.innerHTML = "● Delays"; el.style.color = "red"; }
})
.catch(() => {
    document.getElementById("serviceStatus").innerHTML = "● Unknown";
});
</script>

<script>
let lastAlertCount = 0;

async function refreshAlertsGlobal() {
    const badge = document.getElementById("alertBadge");
    const bell = document.getElementById("alertBell");

    if (sessionStorage.getItem("alertsCleared") === "true") {
        if (badge) badge.style.display = "none";
        return;
    }

    try {
        const res = await fetch('/Alerts?handler=GetActiveAlerts');
        const data = await res.json();
        if (!data.success) return;
        if (badge) {
            badge.innerText = data.alertCount;
            badge.style.display = data.alertCount > 0 ? "inline-block" : "none";
            if (data.alertCount > lastAlertCount && bell) {
                bell.classList.add("bell-animate");
                setTimeout(() => bell.classList.remove("bell-animate"), 600);
            }
            lastAlertCount = data.alertCount;
        }
    } catch {
        console.log("alert badge failed");
    }
}

refreshAlertsGlobal();
setInterval(refreshAlertsGlobal, 15000);
</script>

<!-- FAVOURITES DROPDOWN -->
<script>
document.getElementById('favBtn').addEventListener('show.bs.dropdown', function () {
    fetch('/Account?handler=Favourites')
        .then(res => res.json())
        .then(data => {
            const list = document.getElementById('favList');
            if (!data.loggedIn) {
                list.innerHTML = '<a class="dropdown-item text-muted" href="/Login" style="font-size:13px;">Log in to see favourites</a>';
                return;
            }
            if (!data.stations || data.stations.length === 0) {
                list.innerHTML = '<div class="dropdown-item text-muted" style="font-size:13px;">No favourites yet — add them on your account page.</div>';
                return;
            }
            list.innerHTML = data.stations.map(s =>
                `<li><a class="dropdown-item" href="/Departures?stationName=${encodeURIComponent(s)}" style="font-size:13px;">🚉 ${s}</a></li>`
            ).join('');
        })
        .catch(() => {
            document.getElementById('favList').innerHTML = '<div class="dropdown-item text-muted" style="font-size:13px;">Could not load favourites.</div>';
        });
});
</script>

@RenderSection("Scripts", required: false)

</body>
</html>