@page
@model TrainProject.Models.WebsitePage.Pages.DeparturesModel
@{
    ViewData["Title"] = "Departures & Arrivals";
}

<style>
    /* Card containers */
    .board-card {
        background: white;
        border-radius: 14px;
        box-shadow: 0 4px 18px rgba(75, 78, 109, 0.13);
        overflow: hidden;
        margin-bottom: 2rem;
    }

    .board-card-header {
        padding: 1rem 1.5rem;
        border-bottom: 1.5px solid #dde8f5;
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
    }

    .board-card-header h3 {
        font-size: 1.1rem;
        font-weight: 700;
        color: #4B4E6D;
        margin: 0;
    }

    .board-card-header .subtitle {
        font-size: 0.85rem;
        color: #8a90b0;
    }

    /* Search card */
    .search-card {
        background: white;
        border-radius: 14px;
        box-shadow: 0 4px 18px rgba(75, 78, 109, 0.13);
        padding: 1.25rem 1.5rem;
        margin-bottom: 2rem;
    }

    .search-card .form-control {
        border: 1.5px solid #c5d5e8;
        border-radius: 8px;
        background: #f0f6fb;
        color: #4B4E6D;
        font-size: 0.95rem;
    }

    .search-card .form-control:focus {
        border-color: #4B4E6D;
        background: white;
        box-shadow: none;
    }

    .search-card .btn-primary {
        background-color: #4B4E6D;
        border-color: #4B4E6D;
        border-radius: 8px;
        font-weight: 600;
        padding: 0.5rem 1.4rem;
    }

    .search-card .btn-primary:hover {
        background-color: #3a3d58;
        border-color: #3a3d58;
    }

    /* Page title */
    .page-title {
        font-family: 'Dancing Script', cursive;
        font-size: 2.4rem;
        color: #4B4E6D;
        text-align: center;
        margin-bottom: 0.3rem;
    }

    .page-subtitle {
        text-align: center;
        color: #5a6080;
        margin-bottom: 1.8rem;
        font-size: 0.95rem;
    }

    /* Table */
    .board-table {
        width: 100%;
        border-collapse: collapse;
        margin: 0;
    }

    .board-table thead th {
        padding: 0.7rem 1.4rem;
        font-size: 0.78rem;
        font-weight: 700;
        color: #8a90b0;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-bottom: 1.5px solid #dde8f5;
        background: transparent;
    }

    .board-table tbody tr {
        border-bottom: 1px solid #edf3fb;
        transition: background 0.15s;
    }

    .board-table tbody tr:last-child {
        border-bottom: none;
    }

    .board-table tbody tr:hover {
        background: #f4f8fd;
    }

    .board-table tbody td {
        padding: 0.85rem 1.4rem;
        font-size: 0.93rem;
        color: #2c2f4a;
        vertical-align: middle;
    }

    /* Platform badge */
    .platform-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        background: #e8edf8;
        border-radius: 7px;
        font-weight: 700;
        font-size: 0.88rem;
        color: #4B4E6D;
    }

    /* Status colours */
    .status-on-time   { color: #2eaa6e; font-weight: 600; }
    .status-delayed   { color: #d4820a; font-weight: 600; }
    .status-cancelled { color: #c0392b; font-weight: 600; }

    /* Legend */
    .status-legend {
        display: flex;
        flex-wrap: wrap;
        gap: 1.2rem;
        padding: 0.75rem 1.4rem;
        border-top: 1.5px solid #dde8f5;
        font-size: 0.8rem;
        color: #8a90b0;
    }

    .legend-item { display: flex; align-items: center; gap: 0.35rem; }
    .legend-dot  { width: 8px; height: 8px; border-radius: 50%; }
    .dot-green  { background: #2eaa6e; }
    .dot-orange { background: #d4820a; }
    .dot-red    { background: #c0392b; }
    .dot-grey   { background: #b0bec5; }

    /* Empty state */
    .empty-state {
        text-align: center;
        padding: 2.5rem;
        color: #9aaabb;
        font-size: 0.93rem;
    }

    .empty-icon { font-size: 2rem; display: block; margin-bottom: 0.5rem; opacity: 0.5; }

    /* Delay badge */
    .delay-tag {
        font-size: 0.78rem;
        background: #fff3e0;
        color: #d4820a;
        border-radius: 5px;
        padding: 0.15rem 0.45rem;
        margin-left: 0.4rem;
        font-weight: 600;
    }
</style>

<!-- Header -->
<h1 class="page-title">Departures Board</h1>
<p class="page-subtitle">Upcoming train departures for the <strong>Elizabeth Line</strong></p>

<!-- Search -->
<div class="search-card">
    <form method="get">
        <div class="input-group">
            <input type="text"
                   name="station"
                   class="form-control form-control-lg"
                   placeholder="Search for a station e.g. Paddington"
                   value="@Model.searchedStation" />
            <button class="btn btn-primary btn-lg" type="submit">Search</button>
        </div>
    </form>
</div>

<!-- Departures -->
<div class="board-card">
    <div class="board-card-header">
        <h3>Departures</h3>
        @if (!string.IsNullOrEmpty(Model.searchedStation))
        {
            <span class="subtitle">from @Model.searchedStation</span>
        }
    </div>
    <table class="board-table">
        <thead>
            <tr>
                <th>Platform</th>
                <th>Destination</th>
                <th>Departure</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.departures.Count == 0)
            {
                <tr>
                    <td colspan="4">
                        <div class="empty-state">
                            <span class="empty-icon">🚂</span>
                            Search for a station to see departures
                        </div>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var d in Model.departures)
                {
                    string statusClass = d.Status?.ToLower() switch
                    {
                        "on time"   => "status-on-time",
                        "delayed"   => "status-delayed",
                        "cancelled" => "status-cancelled",
                        _           => "status-on-time"
                    };
                    <tr>
                        <td><span class="platform-badge">@d.Platform</span></td>
                        <td>@d.Destination</td>
                        <td>@d.ScheduledDeparture</td>
                        <td>
                            <span class="@statusClass">@d.Status</span>
                            @if (d.DelayMinutes > 0)
                            {
                                <span class="delay-tag">+@d.DelayMinutes mins</span>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
    <div class="status-legend">
        <span class="legend-item"><span class="legend-dot dot-green"></span> On Time</span>
        <span class="legend-item"><span class="legend-dot dot-orange"></span> Delayed</span>
        <span class="legend-item"><span class="legend-dot dot-red"></span> Cancelled</span>
        <span class="legend-item"><span class="legend-dot dot-grey"></span> No Service</span>
    </div>
</div>

<!-- Arrivals -->
<div class="board-card">
    <div class="board-card-header">
        <h3>Arrivals</h3>
        @if (!string.IsNullOrEmpty(Model.searchedStation))
        {
            <span class="subtitle">at @Model.searchedStation</span>
        }
    </div>
    <table class="board-table">
        <thead>
            <tr>
                <th>Platform</th>
                <th>Origin</th>
                <th>Arrival</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.arrivals.Count == 0)
            {
                <tr>
                    <td colspan="4">
                        <div class="empty-state">
                            <span class="empty-icon">🚉</span>
                            Search for a station to see arrivals
                        </div>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var a in Model.arrivals)
                {
                    string statusClass = a.Status?.ToLower() switch
                    {
                        "on time"   => "status-on-time",
                        "delayed"   => "status-delayed",
                        "cancelled" => "status-cancelled",
                        _           => "status-on-time"
                    };
                    <tr>
                        <td><span class="platform-badge">@a.Platform</span></td>
                        <td>@a.Origin</td>
                        <td>@a.ScheduledArrival</td>
                        <td>
                            <span class="@statusClass">@a.Status</span>
                            @if (a.DelayMinutes > 0)
                            {
                                <span class="delay-tag">+@a.DelayMinutes mins</span>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
    <div class="status-legend">
        <span class="legend-item"><span class="legend-dot dot-green"></span> On Time</span>
        <span class="legend-item"><span class="legend-dot dot-orange"></span> Delayed</span>
        <span class="legend-item"><span class="legend-dot dot-red"></span> Cancelled</span>
        <span class="legend-item"><span class="legend-dot dot-grey"></span> No Service</span>
    </div>
</div>

@section Scripts {
    <script>
        // list of elizabeth line stations for autocomplete
        const elizabethLineStations = [
            "Abbey Wood", "Acton Main Line", "Bond Street", "Canary Wharf",
            "Custom House", "Chadwell Heath", "Forest Gate", "Gidea Park",
            "Harold Wood", "Heathrow Terminal 2 & 3", "Heathrow Terminal 4",
            "Heathrow Terminal 5", "Ilford", "Langdon Park", "Liverpool Street",
            "London Bridge", "Maidenhead", "Manor Park", "Maryland",
            "Paddington", "Reading", "Romford", "Seven Kings",
            "Shenfield", "Slough", "Southall", "Stratford",
            "Tottenham Court Road", "West Drayton", "Whitechapel"
        ];

        // ---- autocomplete ----
        const searchInput = document.querySelector('input[name="station"]');
        
        // create the dropdown container
        const suggestionBox = document.createElement('ul');
        suggestionBox.style.cssText = `
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: white;
            border: 1.5px solid #c5d5e8;
            border-top: none;
            border-radius: 0 0 8px 8px;
            list-style: none;
            margin: 0;
            padding: 0;
            z-index: 999;
            box-shadow: 0 4px 12px rgba(75,78,109,0.12);
            display: none;
        `;

        // wrap the input so dropdown sits underneath it
        const inputWrapper = searchInput.parentElement;
        inputWrapper.style.position = 'relative';
        inputWrapper.appendChild(suggestionBox);

        searchInput.addEventListener('input', function() {
            const typed = this.value.trim().toLowerCase();
            suggestionBox.innerHTML = '';

            if (typed.length < 2) {
                suggestionBox.style.display = 'none';
                return;
            }

            // filter stations that match what the user typed
            const matches = elizabethLineStations.filter(s =>
                s.toLowerCase().includes(typed)
            );

            if (matches.length === 0) {
                suggestionBox.style.display = 'none';
                return;
            }

            matches.forEach(station => {
                const li = document.createElement('li');
                li.textContent = station;
                li.style.cssText = `
                    padding: 0.6rem 1rem;
                    cursor: pointer;
                    font-size: 0.93rem;
                    color: #2c2f4a;
                    border-bottom: 1px solid #f0f5fc;
                `;
                li.addEventListener('mouseenter', () => li.style.background = '#f4f8fd');
                li.addEventListener('mouseleave', () => li.style.background = 'white');
                li.addEventListener('click', () => {
                    searchInput.value = station;
                    suggestionBox.style.display = 'none';
                });
                suggestionBox.appendChild(li);
            });

            suggestionBox.style.display = 'block';
        });

        // hide suggestions if user clicks away
        document.addEventListener('click', function(e) {
            if (!inputWrapper.contains(e.target)) {
                suggestionBox.style.display = 'none';
            }
        });

        // ---- form validation ----
        const searchForm = document.querySelector('form');
        searchForm.addEventListener('submit', function(e) {
            const val = searchInput.value.trim();

            // check the station they typed is actually on the elizabeth line
            const isValid = elizabethLineStations.some(s =>
                s.toLowerCase() === val.toLowerCase()
            );

            if (val === '') {
                e.preventDefault();
                showError('Please enter a station name');
            } else if (!isValid) {
                e.preventDefault();
                showError('Station not found on the Elizabeth Line — try selecting from the dropdown');
            }
        });

        function showError(message) {
            // remove any existing error first
            const existing = document.getElementById('station-error');
            if (existing) existing.remove();

            const err = document.createElement('p');
            err.id = 'station-error';
            err.textContent = message;
            err.style.cssText = `
                color: #c0392b;
                font-size: 0.85rem;
                margin: 0.4rem 0 0 0.2rem;
            `;
            searchInput.parentElement.parentElement.appendChild(err);
        }

        // ---- animate cards on load ----
        const cards = document.querySelectorAll('.board-card');
        cards.forEach((card, i) => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(18px)';
            card.style.transition = `opacity 0.4s ease ${i * 0.15}s, transform 0.4s ease ${i * 0.15}s`;

            // slight delay so the transition actually fires
            setTimeout(() => {
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
            }, 50);
        });

        // ---- live status refresh ----
        // only run if a station has been searched
        const currentStation = '@Model.searchedStation';
        if (currentStation) {
            setInterval(function() {
                // reload the page silently to get fresh data from the db
                // keeps the current station in the search
                const url = new URL(window.location.href);
                url.searchParams.set('station', currentStation);

                fetch(url.toString())
                    .then(res => res.text())
                    .then(html => {
                        // parse the response and pull out the updated tables
                        const parser = new DOMParser();
                        const newDoc = parser.parseFromString(html, 'text/html');
                        const newCards = newDoc.querySelectorAll('.board-card');
                        const oldCards = document.querySelectorAll('.board-card');

                        oldCards.forEach((card, i) => {
                            if (newCards[i]) {
                                card.innerHTML = newCards[i].innerHTML;
                            }
                        });
                    })
                    .catch(() => {
                        // silently fail if refresh doesn't work
                        console.log('Status refresh failed, will retry shortly');
                    });

            }, 30000); // refresh every 30 seconds
        }
    </script>
}