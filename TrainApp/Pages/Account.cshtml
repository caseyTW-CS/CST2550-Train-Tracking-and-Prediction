@page
@model TrainApp.Pages.AccountModel

@{
ViewData["Title"] = "My Account";
}

<!-- page header -->

<div class="text-center mb-4">
    <h1 class="display-4">My Account</h1>
    <p class="lead">Manage your LineTrack settings and preferences</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">


    <!-- account details card -->
    <div class="card p-4 mb-4">
        <h3 class="mb-3">Account Details</h3>
        <table class="table">
            <tr>
                <td class="text-muted">Username</td>
                <td>@Model.userName</td>
            </tr>
            <tr>
                <td class="text-muted">Email</td>
                <td>@Model.userEmail</td>
            </tr>
            <tr>
                <td class="text-muted">Age</td>
                <td>@Model.userAge</td>
            </tr>
            <tr>
                <td class="text-muted">Phone</td>
                <td>@Model.userPhone</td>
            </tr>
        </table>
    </div>

    <!-- favourite stations card -->
    <div class="card p-4 mb-4">
        <h3 class="mb-3">Favourite Stations</h3>

        <!-- add favourite station -->
        <form method="post" asp-page-handler="AddFavourite">
    <div class="input-group mb-3">
        <input name="stationName" class="form-control" placeholder="Add a favourite station e.g. Paddington" />
        <button class="btn btn-primary" type="submit">Add</button>
    </div>
        </form>

        <!-- list of favourites -->
        <ul class="list-group">
    @if (Model.favouriteStations.Count == 0)
    {
        <li class="list-group-item text-muted">No favourite stations added yet</li>
    }
    else
    {
        @foreach (var station in Model.favouriteStations)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                @station

                <form method="post" asp-page-handler="RemoveFavourite">
                    <input type="hidden" name="stationName" value="@station" />
                    <button class="btn btn-sm btn-danger">Remove</button>
                </form>
            </li>
        }
    }
</ul>
    </div>

    <!-- recent searches card -->
    <div class="card p-4">
        <h3 class="mb-3">Recent Searches</h3>
        <ul class="list-group">
            <li class="list-group-item text-muted">No recent searches</li>
        </ul>

        <!-- clear recent searches button -->
        <button class="btn btn-outline-danger mt-3">Clear Recent Searches</button>
    </div>

</div>


</div>
