@page
@model TestReposit.Models.WebsitePage.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<style>
    .container {
        max-width: 100%;
        padding: 0 20px;
    }

    .login-wrapper {
        display: flex;
        height: 80vh;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        max-width: 900px;
        margin: 0 auto;
    }

    /* left navy blue panel */
    .login-left {
        background-color: #4B4E6D;
        color: white;
        width: 40%;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 40px;
        text-align: center;
    }

    /* right white panel */
    .login-right {
        width: 60%;
        flex-shrink: 0;
        overflow: hidden;
        position: relative;
        background-color: white;
    }

    /* slider sits inside login-right and is twice as wide */
    .forms-slider {
        display: flex;
        width: 200%;
        height: 100%;
        transition: transform 0.5s ease;
    }

    /* each form is exactly half of forms-slider */
    .form-panel {
        width: 50%;
        flex-shrink: 0;
        padding: 40px;
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background-color: white;
        overflow: hidden;
    }

    /* arrow buttons */
    .arrow-container {
        display: flex;
        gap: 12px;
        margin-top: 20px;
        justify-content: center;
    }

    .arrow-btn {
        background: none;
        border: 2px solid white;
        color: white;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        cursor: pointer;
        font-size: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .arrow-btn:hover {
        background-color: white;
        color: #4B4E6D;
    }

    /* input fields - applies to both forms */
    .form-control, .register-form input {
        background-color: #f0f4fa;
        border: none;
        padding: 12px;
        margin-bottom: 12px;
        border-radius: 8px;
        width: 100%;
        box-sizing: border-box;
        font-size: 15px;
    }

    /* navy blue heading */
    .form-title {
        color: #4B4E6D;
        text-align: center;
        margin-bottom: 1.5rem;
    }

    /* submit button - applies to both forms */
    .submit-btn, .register-form button {
        background-color: #4B4E6D;
        color: white;
        border: none;
        padding: 12px;
        border-radius: 25px;
        width: 100%;
        font-size: 16px;
        letter-spacing: 1px;
        margin-top: 10px;
        cursor: pointer;
        box-sizing: border-box;
    }

    .submit-btn:hover, .register-form button:hover {
        background-color: #84DCC6;
        color: #4B4E6D;
    }

    /* makes the register form fill the panel properly */
    .register-form {
        display: flex;
        flex-direction: column;
        width: 100%;
    }
</style>

<div class="login-wrapper">

    <!-- left navy panel -->
    <div class="login-left">
        <h2 id="leftTitle">Welcome Back!</h2>
        <p id="leftText">To keep connected with us please login with your personal info</p>
        <div class="arrow-container">
            <button class="arrow-btn" onclick="slideLeft()">&#8592;</button>
            <button class="arrow-btn" onclick="slideRight()">&#8594;</button>
        </div>
    </div>

    <!-- right white panel -->
    <div class="login-right">
        <div class="forms-slider" id="formsSlider">

<!-- login form -->
<div class="form-panel">
    <h2 class="form-title">Sign In</h2>
    @if (Model.message != null)
    {
        <!-- shows error message if login fails -->
        <div class="alert alert-danger">@Model.message</div>
    }
    <form method="post" asp-page-handler="Login" class="register-form">
        <input asp-for="loginUsername" type="text" placeholder="&#128100; Username" />
        <input asp-for="loginPassword" type="password" placeholder="&#128274; Password" />
        <button type="submit">SIGN IN</button>
    </form>
</div>

            <div class="form-panel">
                <h2 class="form-title">Create Account</h2>
                <form method="post" asp-page-handler="Register" class="register-form">
                    <input asp-for="newUser.userName" placeholder="&#128100; Username" />
                    <input asp-for="newUser.userPass" type="password" placeholder="&#128274; Password" />
                    <input asp-for="newUser.userAge" placeholder="&#128100; Age" />
                    <input asp-for="newUser.userEmail" placeholder="&#9993; Email" />
                    <input asp-for="newUser.userPhone" placeholder="&#128222; Phone" />
                    <button type="submit">SIGN UP</button>
                </form>
            </div>

        </div>
    </div>
</div>

<script>
    let showingRegister = false;

    // slides right to show the register form
    function slideRight() {
        if (!showingRegister) {
            showingRegister = true;
            document.getElementById('formsSlider').style.transform = 'translateX(-50%)';
            document.getElementById('leftTitle').innerText = 'Hello!';
            document.getElementById('leftText').innerText = 'Enter your details and start your journey with us';
        }
    }

    // slides left to show the login form
    function slideLeft() {
        if (showingRegister) {
            showingRegister = false;
            document.getElementById('formsSlider').style.transform = 'translateX(0)';
            document.getElementById('leftTitle').innerText = 'Welcome Back!';
            document.getElementById('leftText').innerText = 'To keep connected with us please login with your personal info';
        }
    }
</script>