@page
@model TrainApp.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}

<style>
    .hero {
        text-align: center;
        padding: 3rem 0 2rem 0;
    }
    .hero-title {
        font-family: 'Dancing Script', cursive;
        font-size: 72px;
        color: #2d4a7a;
        margin-bottom: 1rem;
    }
    .hero-subtitle {
        color: #6b7c93;
        font-size: 18px;
        margin-bottom: 2rem;
    }
    .action-buttons {
        display: flex;
        justify-content: center;
        gap: 12px;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }
    .action-btn {
        padding: 12px 24px;
        border-radius: 25px;
        border: 1.5px solid #d0dce8;
        background: white;
        color: #2d4a7a;
        font-size: 15px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }
    .action-btn.active {
        background-color: #2d4a7a;
        color: white;
        border-color: #2d4a7a;
    }
    .action-btn:hover {
        background-color: #2d4a7a;
        color: white;
        border-color: #2d4a7a;
        text-decoration: none;
    }
    .service-status {
        text-align: center;
        margin-bottom: 2.5rem;
    }
    .status-dot {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: #28a745;
        margin-right: 6px;
    }
    .status-text {
        font-size: 17px;
        font-weight: 500;
        color: #2d4a7a;
    }
    .status-sub {
        color: #6b7c93;
        font-size: 14px;
        margin-top: 4px;
    }
    .cards-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 3rem;
    }
    .info-card {
        background: white;
        border-radius: 16px;
        padding: 2rem;
        text-align: center;
        border: 1px solid #e8f0f8;
    }
    .card-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background-color: #e8f2fc;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem auto;
        font-size: 28px;
    }
    .card-title {
        font-size: 18px;
        font-weight: 600;
        color: #2d4a7a;
        margin-bottom: 0.5rem;
    }
    .card-text {
        color: #6b7c93;
        font-size: 14px;
        margin-bottom: 1.5rem;
        line-height: 1.6;
    }
    .card-btn {
        display: block;
        background-color: #4a7cc7;
        color: white;
        padding: 10px 20px;
        border-radius: 25px;
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        width: 100%;
        box-sizing: border-box;
    }
    .card-btn:hover {
        background-color: #2d4a7a;
        color: white;
        text-decoration: none;
    }
    .weather-widget {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 140px;
    background: white;
    border-radius: 12px;
    padding: 0.8rem;
    border: 1px solid #e8f0f8;
    text-align: center;
}

.weather-city {
    font-size: 11px;
    color: #6b7c93;
    margin-bottom: 2px;
}

.weather-temp {
    font-size: 28px;
    font-weight: 600;
    color: #2d4a7a;
    line-height: 1;
    margin: 4px 0;
}

.weather-desc {
    font-size: 11px;
    color: #6b7c93;
    text-transform: capitalize;
    margin-bottom: 6px;
}

.weather-icon {
    font-size: 28px;
    margin-bottom: 4px;
}

.weather-details {
    display: flex;
    justify-content: space-between;
    margin-top: 6px;
    padding-top: 6px;
    border-top: 1px solid #e8f0f8;
    font-size: 11px;
    color: #6b7c93;
}
</style>

<!-- HERO SECTION -->
<div class="hero" style="position: relative;">

    <!-- WEATHER (kept exactly, just cleaner placement) -->
    <div class="weather-widget">
        <div class="weather-city">London, UK</div>
        <div class="weather-icon" id="weatherIcon">&#9925;</div>
        <div class="weather-temp" id="weatherTemp">--°</div>
        <div class="weather-desc" id="weatherDesc">Loading...</div>
        <div class="weather-details">
            <span>&#128167; <span id="weatherHumidity">--%</span></span>
            <span>&#128168; <span id="weatherWind">-- mph</span></span>
        </div>
    </div>

    <h1 class="hero-title">Where's the Train?</h1>
    <p class="hero-subtitle">
        Track trains, check arrivals and plan your journey
    </p>

    <!-- 🔥 REPLACED BUTTONS WITH SEARCH -->
    <div style="max-width:500px; margin:auto;">

        <form method="post" asp-page="/FindTrain">

            <input name="StartId" class="form-control mb-2"
                   placeholder="Start station (e.g. Paddington)" />

            <input name="Destination" class="form-control mb-2"
                   placeholder="Destination (e.g. Abbey Wood)" />

            <button class="action-btn active" style="width:100%; display:block; text-align:center;">
                🔍 Find Trains
            </button>

        </form>

    </div>

</div>

<!-- SERVICE STATUS (UNCHANGED) -->
<div class="service-status">
    <div>
        <span class="status-dot"></span>
        <span class="status-text">Live Service Status</span>
    </div>
    <p class="status-sub">Elizabeth Line: Good Service</p>
</div>

<!-- FEATURE CARDS (UPDATED PURPOSE) -->
<div class="cards-row">

    <div class="info-card">
        <div class="card-icon">&#128205;</div>
        <h3 class="card-title">Track Trains</h3>
        <p class="card-text">
            View live train journeys and track routes across the Elizabeth Line
        </p>
        <a href="/FindTrain" class="card-btn">Find a Train</a>
    </div>

    <div class="info-card">
        <div class="card-icon">&#128643;</div>
        <h3 class="card-title">Departures Board</h3>
        <p class="card-text">
            Check upcoming arrivals and departures for any station on the Elizabeth Line
        </p>
        <a href="/Departures" class="card-btn">View Departures</a>
    </div>

    <div class="info-card">
        <div class="card-icon">&#128276;</div>
        <h3 class="card-title">Service Alerts</h3>
        <p class="card-text">
            Stay updated with delays and disruptions on your route through different stations
        </p>
        <a href="/Alerts" class="card-btn">View Alerts</a>
    </div>

</div>

<script>
    const apiKey = '2ff6c4af53269a664688bc840c7c9367';
    const city = 'London';

    function getWeatherEmoji(code) {
        if (code >= 200 && code < 300) return '&#9928;&#65039;';
        if (code >= 300 && code < 600) return '&#127783;&#65039;';
        if (code >= 600 && code < 700) return '&#10052;&#65039;';
        if (code >= 700 && code < 800) return '&#127787;&#65039;';
        if (code === 800) return '&#9728;&#65039;';
        if (code === 801) return '&#127780;&#65039;';
        if (code >= 802) return '&#9729;&#65039;';
        return '&#127777;&#65039;';
    }

    fetch(`https://api.openweathermap.org/data/2.5/weather?q=${city}&appid=${apiKey}&units=metric`)
        .then(res => res.json())
        .then(data => {
            const temp = Math.round(data.main.temp);
            const desc = data.weather[0].description;
            const humidity = data.main.humidity;
            const wind = Math.round(data.wind.speed * 2.237);
            const code = data.weather[0].id;

            document.getElementById('weatherTemp').textContent = temp + '\u00B0C';
            document.getElementById('weatherDesc').textContent = desc;
            document.getElementById('weatherHumidity').textContent = humidity + '%';
            document.getElementById('weatherWind').textContent = wind + ' mph';
            document.getElementById('weatherIcon').innerHTML = getWeatherEmoji(code);
        })
        .catch(() => {
            document.getElementById('weatherDesc').textContent = 'Weather unavailable';
            document.getElementById('weatherTemp').textContent = '--\u00B0';
        });
</script>
