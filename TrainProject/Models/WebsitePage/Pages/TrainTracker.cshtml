@page
@model TrainProject.Models.WebsitePage.Pages.TrainTrackerModel
@{
    ViewData["Title"] = "Train Tracker";
}

<style>
    .tracker-header {
        text-align: center;
        padding: 2rem 1rem 1.5rem;
    }

    .tracker-header h1 {
        font-family: 'Dancing Script', cursive;
        font-size: 2.6rem;
        color: #1a2f5a;
        margin-bottom: 0.3rem;
    }

    .tracker-header p {
        color: #4a6080;
        font-size: 0.95rem;
    }

    .tracker-wrap {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 1rem 3rem;
    }

    .search-card {
        background: white;
        border-radius: 14px;
        box-shadow: 0 4px 18px rgba(75,78,109,0.13);
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.2rem;
    }

    .search-card .form-control {
        border: 1.5px solid #c5d5e8;
        border-radius: 8px;
        background: #f0f6fb;
        color: #4B4E6D;
        font-size: 0.95rem;
    }

    .search-card .form-control:focus {
        border-color: #4B4E6D;
        background: white;
        box-shadow: none;
    }

    .search-card .btn-primary {
        background-color: #1b6ec2;
        border-color: #1861ac;
        border-radius: 8px;
        font-weight: 600;
        padding: 0.5rem 1.6rem;
    }

    .search-card .btn-primary:hover {
        background-color: #1861ac;
    }

    .map-card {
        background: white;
        border-radius: 14px;
        box-shadow: 0 4px 18px rgba(75,78,109,0.13);
        overflow: hidden;
        margin-bottom: 1.2rem;
    }

    .map-card-header {
        padding: 0.9rem 1.4rem;
        border-bottom: 1.5px solid #dde8f5;
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        user-select: none;
    }

    .map-card-header:hover { background: #f8fafd; }

    .map-card-header-left {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .map-card-header h3 {
        font-size: 1rem;
        font-weight: 700;
        color: #4B4E6D;
        margin: 0;
    }

    .elizabeth-pill {
        background: #6950a1;
        color: white;
        border-radius: 20px;
        padding: 0.2rem 0.8rem;
        font-size: 0.75rem;
        font-weight: 700;
    }

    .map-header-right {
        display: flex;
        align-items: center;
        gap: 0.8rem;
    }

    .train-id-badge {
        background: #4B4E6D;
        color: white;
        border-radius: 6px;
        padding: 0.2rem 0.7rem;
        font-size: 0.78rem;
        font-weight: 700;
        display: none;
    }

    .delay-badge {
        background: #fff3e0;
        color: #d4820a;
        border-radius: 6px;
        padding: 0.2rem 0.7rem;
        font-size: 0.78rem;
        font-weight: 700;
        display: none;
    }

    .expand-btn {
        background: #e8edf8;
        border: none;
        border-radius: 6px;
        padding: 0.25rem 0.7rem;
        font-size: 0.8rem;
        color: #4B4E6D;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
    }

    .expand-btn:hover { background: #d0d8f0; }

    .map-body {
        overflow: hidden;
        transition: max-height 0.4s ease;
        max-height: 300px;
    }

    .map-body.expanded { max-height: 600px; }

    .line-map-wrap {
        padding: 1.5rem 1rem 0.5rem;
        overflow-x: auto;
    }

    .line-map {
        position: relative;
        min-width: 700px;
        height: 90px;
    }

    .line-track {
        position: absolute;
        top: 32px;
        left: 10px;
        right: 10px;
        height: 6px;
        background: #c5d5e8;
        border-radius: 3px;
    }

    .line-track-progress {
        height: 100%;
        background: #6950a1;
        border-radius: 3px;
        width: 0%;
        transition: width 0.6s ease;
    }

    .stations-row {
        position: absolute;
        top: 0;
        left: 10px;
        right: 10px;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .station-stop {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .station-dot {
        width: 13px;
        height: 13px;
        border-radius: 50%;
        background: white;
        border: 3px solid #c5d5e8;
        margin-top: 26px;
        z-index: 2;
        transition: all 0.3s;
    }

    .station-stop.passed .station-dot {
        border-color: #6950a1;
        background: #6950a1;
    }

    .station-stop.current .station-dot {
        border-color: #6950a1;
        background: white;
        width: 17px;
        height: 17px;
        margin-top: 24px;
        box-shadow: 0 0 0 4px rgba(105,80,161,0.2);
    }

    .station-label {
        font-size: 0.58rem;
        color: #8a90b0;
        margin-top: 5px;
        text-align: center;
        max-width: 50px;
        line-height: 1.2;
        word-break: break-word;
    }

    .station-stop.current .station-label {
        color: #6950a1;
        font-weight: 700;
    }

    .train-marker {
        position: absolute;
        top: 14px;
        font-size: 1.2rem;
        transform: translateX(-50%);
        transition: left 0.6s ease;
        z-index: 5;
        display: none;
    }

    .tfl-live-section {
        border-top: 1.5px solid #dde8f5;
        padding: 1rem 1.2rem;
        display: none;
    }

    .tfl-live-section.visible { display: block; }

    .tfl-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1rem;
    }

    .tfl-header-left {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: #4B4E6D;
    }

    .live-dot {
        width: 8px;
        height: 8px;
        background: #2eaa6e;
        border-radius: 50%;
        animation: pulse 1.5s infinite;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
    }

    .refresh-btn {
        background: #4B4E6D;
        color: white;
        border: none;
        border-radius: 7px;
        padding: 0.3rem 0.9rem;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
    }

    .refresh-btn:hover { background: #3a3d58; }

    .tfl-trains-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 0.8rem;
        max-height: 280px;
        overflow-y: auto;
    }

    .tfl-train-card {
        background: #f4f8fd;
        border-radius: 10px;
        padding: 0.8rem 1rem;
        border-left: 3px solid #6950a1;
        font-size: 0.82rem;
    }

    .tfl-train-card-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.4rem;
    }

    .tfl-vehicle-id { font-weight: 700; color: #4B4E6D; }

    .badge-ontime { background: #e8f8f0; color: #2eaa6e; border-radius: 5px; padding: 0.1rem 0.45rem; font-size: 0.72rem; font-weight: 600; }
    .badge-delayed { background: #fff3e0; color: #d4820a; border-radius: 5px; padding: 0.1rem 0.45rem; font-size: 0.72rem; font-weight: 600; }

    .tfl-train-detail { color: #6a7a9a; line-height: 1.7; }
    .tfl-train-detail strong { color: #2c2f4a; }

    .tfl-loading {
        text-align: center;
        padding: 1.5rem;
        color: #8a90b0;
        font-size: 0.85rem;
    }

    .spinner {
        width: 28px;
        height: 28px;
        border: 3px solid #e8edf8;
        border-top-color: #6950a1;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 0 auto 0.6rem;
    }

    @@keyframes spin { to { transform: rotate(360deg); } }

    .last-updated { font-size: 0.75rem; color: #8a90b0; }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.2rem;
        margin-bottom: 1.2rem;
    }

    .info-card {
        background: white;
        border-radius: 14px;
        box-shadow: 0 4px 18px rgba(75,78,109,0.13);
        overflow: hidden;
    }

    .info-card-header {
        padding: 0.9rem 1.4rem;
        border-bottom: 1.5px solid #dde8f5;
    }

    .info-card-header h3 {
        font-size: 1rem;
        font-weight: 700;
        color: #4B4E6D;
        margin: 0;
    }

    .info-table { width: 100%; border-collapse: collapse; }
    .info-table tr { border-bottom: 1px solid #f0f5fc; }
    .info-table tr:last-child { border-bottom: none; }

    .info-table td {
        padding: 0.75rem 1.4rem;
        font-size: 0.88rem;
        vertical-align: middle;
    }

    .info-table td:first-child { color: #8a90b0; width: 55%; }
    .info-table td:last-child { color: #2c2f4a; font-weight: 600; }

    .placeholder-val { color: #b0bec5 !important; font-weight: 400 !important; }

    .live-strip {
        background: white;
        border-radius: 14px;
        box-shadow: 0 4px 18px rgba(75,78,109,0.13);
        overflow: hidden;
        margin-bottom: 2rem;
    }

    .live-strip-header {
        padding: 0.9rem 1.4rem;
        border-bottom: 1.5px solid #dde8f5;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .live-strip-header h3 {
        font-size: 1rem;
        font-weight: 700;
        color: #4B4E6D;
        margin: 0;
    }

    .live-table { width: 100%; border-collapse: collapse; }

    .live-table thead th {
        padding: 0.6rem 1.4rem;
        font-size: 0.75rem;
        font-weight: 700;
        color: #8a90b0;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-bottom: 1.5px solid #dde8f5;
    }

    .live-table tbody tr { border-bottom: 1px solid #f0f5fc; }
    .live-table tbody tr:last-child { border-bottom: none; }
    .live-table tbody tr:hover { background: #f4f8fd; }

    .live-table tbody td {
        padding: 0.75rem 1.4rem;
        font-size: 0.88rem;
        color: #2c2f4a;
    }

    .platform-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 26px;
        height: 26px;
        background: #e8edf8;
        border-radius: 6px;
        font-weight: 700;
        font-size: 0.82rem;
        color: #4B4E6D;
    }

    .error-banner {
        background: #fff3e0;
        border-radius: 10px;
        padding: 0.8rem 1.2rem;
        color: #d4820a;
        margin-bottom: 1rem;
        font-size: 0.88rem;
    }

    @@media (max-width: 700px) {
        .info-grid { grid-template-columns: 1fr; }
    }
</style>

<!-- header -->
<div class="tracker-header">
    <h1>Elizabeth Line – Train Tracker</h1>
    <p>See where any Elizabeth Line train is right now</p>
</div>

<div class="tracker-wrap">

    <!-- search bar -->
    <div class="search-card">
        <form method="get">
            <div class="input-group">
                <input type="text" name="trainId" id="trainInput"
                       class="form-control form-control-lg"
                       placeholder="Enter train number e.g. TL1234"
                       value="@Model.searchedTrain" />
                <button class="btn btn-primary btn-lg" type="submit">Track</button>
            </div>
        </form>
    </div>

    <!-- error message if train not found -->
    @if (!string.IsNullOrEmpty(Model.errorMessage))
    {
        <div class="error-banner">&#9888;&#65039; @Model.errorMessage</div>
    }

    <!-- shows where the data came from -->
    @if (!string.IsNullOrEmpty(Model.dataSource))
    {
        <div style="font-size: 0.8rem; color: #8a90b0; margin-bottom: 0.8rem; padding-left: 0.2rem;">
            @if (Model.dataSource == "database")
            {
                <span>&#128197; Data from our database</span>
            }
            else
            {
                <span>&#128246; Live data from TfL API</span>
            }
        </div>
    }

    <!-- live map card with expand toggle -->
    <div class="map-card">
        <div class="map-card-header" onclick="toggleMapExpand()">
            <div class="map-card-header-left">
                <h3>Live Map</h3>
                <span class="elizabeth-pill">Elizabeth Line</span>
            </div>
            <div class="map-header-right">
                <span class="train-id-badge" id="trainIdBadge"></span>
                <span class="delay-badge" id="delayBadge"></span>
                <button class="expand-btn" id="expandBtn">&#10562; Expand</button>
            </div>
        </div>

        <div class="map-body" id="mapBody">
            <!-- train position line -->
            <div class="line-map-wrap">
                <div class="line-map" id="lineMap">
                    <div class="line-track">
                        <div class="line-track-progress" id="trackProgress"></div>
                    </div>
                    <div class="stations-row" id="stationsRow"></div>
                    <div class="train-marker" id="trainMarker">&#128642;</div>
                </div>
            </div>

            <!-- expanded TfL live section -->
            <div class="tfl-live-section" id="tflLiveSection">
                <div class="tfl-header">
                    <div class="tfl-header-left">
                        <span class="live-dot"></span>
                        <span id="tflStatus">All live trains on the Elizabeth Line</span>
                    </div>
                    <div style="display:flex; align-items:center; gap:0.6rem;">
                        <span class="last-updated" id="tflLastUpdated"></span>
                        <button class="refresh-btn" onclick="event.stopPropagation(); fetchLiveTrains()">&#8635; Refresh</button>
                    </div>
                </div>
                <div id="tflTrainsWrap">
                    <div class="tfl-loading">
                        <div class="spinner"></div>
                        Loading live trains...
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- current position and predicted arrival cards -->
    <div class="info-grid">
        <div class="info-card">
            <div class="info-card-header"><h3>Current Position</h3></div>
            <table class="info-table">
                <tr>
                    <td>Train Number</td>
                    <td>
                        @if (Model.arrivals.Count > 0)
                        {
                            @Model.arrivals[0].VehicleId
                        }
                        else
                        {
                            <span class="placeholder-val">Search for a train</span>
                        }
                    </td>
                </tr>
                <tr>
                    <td>Current Location</td>
                    <td>
                        @if (Model.arrivals.Count > 0)
                        {
                            @Model.arrivals[0].CurrentLocation
                        }
                        else
                        {
                            <span class="placeholder-val">--</span>
                        }
                    </td>
                </tr>
                <tr>
                    <td>Next Station</td>
                    <td>
                        @if (Model.arrivals.Count > 0)
                        {
                            @Model.arrivals[0].StationName
                        }
                        else
                        {
                            <span class="placeholder-val">--</span>
                        }
                    </td>
                </tr>
                <tr>
                    <td>Time to Next Station</td>
                    <td>
                        @if (Model.arrivals.Count > 0)
                        {
                            @Model.arrivals[0].TimeToStation
                        }
                        else
                        {
                            <span class="placeholder-val">--</span>
                        }
                    </td>
                </tr>
                <tr>
                    <td>Platform</td>
                    <td>
                        @if (Model.arrivals.Count > 0)
                        {
                            @Model.arrivals[0].Platform
                        }
                        else
                        {
                            <span class="placeholder-val">--</span>
                        }
                    </td>
                </tr>
            </table>
        </div>

        <div class="info-card">
            <div class="info-card-header"><h3>Predicted Arrival</h3></div>
            <table class="info-table">
                <tr>
                    <td>Final Destination</td>
                    <td>
                        @if (Model.arrivals.Count > 0)
                        {
                            @Model.arrivals[0].Destination
                        }
                        else
                        {
                            <span class="placeholder-val">--</span>
                        }
                    </td>
                </tr>
                <tr>
                    <td>Expected Arrival</td>
                    <td>
                        @if (Model.arrivals.Count > 0)
                        {
                            @Model.arrivals[0].ExpectedArrival
                        }
                        else
                        {
                            <span class="placeholder-val">--</span>
                        }
                    </td>
                </tr>
            </table>
        </div>
    </div>

    <!-- live departures board -->
    <div class="live-strip">
        <div class="live-strip-header">
            <span class="live-dot"></span>
            <h3>Live Departures Board</h3>
        </div>
        <table class="live-table">
            <thead>
                <tr>
                    <th>Station</th>
                    <th>Platform</th>
                    <th>Expected</th>
                    <th>Time Away</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.arrivals.Count == 0)
                {
                    <tr>
                        <td colspan="4" style="text-align:center; color:#b0bec5; padding:1.5rem;">
                            Track a train to see live departures
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var arrival in Model.arrivals)
                    {
                        <tr>
                            <td>@arrival.StationName</td>
                            <td><span class="platform-badge">@arrival.Platform</span></td>
                            <td>@arrival.ExpectedArrival</td>
                            <td>@arrival.TimeToStation</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

</div>

@section Scripts {
<script>
    const TFL_KEY = 'bd620c86b82b487bb8d7b7f41c54d10b';
    let isExpanded = false;
    let tflLoaded = false;

const allStations = [
    // reading branch
    "Reading", "Twyford", "Maidenhead", "Taplow", "Burnham", "Slough",
    "Langley", "Iver", "West Drayton", "Hayes & Harlington",
    // heathrow branch
    "Heathrow Terminal 2 & 3", "Heathrow Terminal 4", "Heathrow Terminal 5",
    // back to main line
    "Southall", "Hanwell", "West Ealing", "Ealing Broadway",
    "Acton Main Line", "Paddington", "Bond Street", "Tottenham Court Road",
    "Farringdon", "City Thameslink", "Liverpool Street", "Whitechapel",
    // shenfield branch
    "Stratford", "Maryland", "Forest Gate", "Manor Park", "Ilford",
    "Seven Kings", "Goodmayes", "Chadwell Heath", "Romford", "Gidea Park",
    "Harold Wood", "Brentwood", "Shenfield",
    // abbey wood branch
    "Shadwell", "Wapping", "Rotherhithe", "Canada Water",
    "Surrey Quays", "New Cross", "New Cross Gate", "Abbey Wood"
];

    // build the station dots on the line map
    function buildMap() {
        const row = document.getElementById('stationsRow');
        if (!row) return;
        row.innerHTML = '';
        allStations.forEach((name, i) => {
            const stop = document.createElement('div');
            stop.className = 'station-stop';
            stop.id = 'stop-' + i;
            stop.innerHTML = `<div class="station-dot"></div><div class="station-label">${name}</div>`;
            row.appendChild(stop);
        });

        // position the train marker based on the next station from the database
        const nextStation = '@(Model.arrivals.Count > 0 ? Model.arrivals[0].StationName : "")';
        if (nextStation) {
            const nextIndex = allStations.findIndex(s =>
                nextStation.toLowerCase().includes(s.toLowerCase())
            );
            if (nextIndex > 0) updateMap(nextIndex - 1);
        }
    }

    // moves the train marker and colours the passed stations purple
    function updateMap(currentIndex) {
        document.querySelectorAll('.station-stop').forEach((stop, i) => {
            stop.classList.remove('passed', 'current');
            if (i < currentIndex) stop.classList.add('passed');
            if (i === currentIndex) stop.classList.add('current');
        });

        const marker = document.getElementById('trainMarker');
        const progress = document.getElementById('trackProgress');
        if (!marker || !progress) return;

        const pct = (currentIndex / (allStations.length - 1)) * 100;
        marker.style.left = pct + '%';
        marker.style.display = 'block';
        progress.style.width = pct + '%';
    }

    // expands the map to show live TfL trains when clicked
    function toggleMapExpand() {
        const mapBody = document.getElementById('mapBody');
        const tflSection = document.getElementById('tflLiveSection');
        const expandBtn = document.getElementById('expandBtn');

        isExpanded = !isExpanded;

        if (isExpanded) {
            mapBody.classList.add('expanded');
            tflSection.classList.add('visible');
            expandBtn.textContent = '⤡ Collapse';
            // only fetch TfL data the first time to avoid unnecessary calls
            if (!tflLoaded) {
                fetchLiveTrains();
                tflLoaded = true;
            }
        } else {
            mapBody.classList.remove('expanded');
            tflSection.classList.remove('visible');
            expandBtn.textContent = '⤢ Expand';
        }
    }

    // fetches all live trains from the TfL API
    async function fetchLiveTrains() {
        const wrap = document.getElementById('tflTrainsWrap');
        wrap.innerHTML = '<div class="tfl-loading"><div class="spinner"></div>Loading live trains...</div>';

        try {
            const res = await fetch(
                `https://api.tfl.gov.uk/Line/elizabeth/Arrivals?app_key=${TFL_KEY}`
            );
            if (!res.ok) throw new Error('TfL API error ' + res.status);

            const data = await res.json();

            // remove duplicates by vehicle id
            const unique = {};
            data.forEach(t => {
                if (!unique[t.vehicleId]) unique[t.vehicleId] = t;
            });

            const trains = Object.values(unique);
            document.getElementById('tflStatus').textContent =
                trains.length + ' live trains on the Elizabeth Line';
            document.getElementById('tflLastUpdated').textContent =
                'Updated ' + new Date().toLocaleTimeString('en-GB', {
                    hour: '2-digit', minute: '2-digit', second: '2-digit'
                });

            if (trains.length === 0) {
                wrap.innerHTML = '<div class="tfl-loading" style="color:#b0bec5">No live trains found</div>';
                return;
            }

            wrap.innerHTML = `<div class="tfl-trains-grid">${
                trains.map(t => {
                    const mins = Math.round((t.timeToStation || 0) / 60);
                    const delayed = mins > 5;
                    const dest = (t.destinationName || 'Unknown').replace(' Rail Station', '');
                    const stn = (t.stationName || '--').replace(' Rail Station', '').replace(' Underground Station', '');
                    const arr = t.expectedArrival
                        ? new Date(t.expectedArrival).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' })
                        : '--';
                    return `
                        <div class="tfl-train-card">
                            <div class="tfl-train-card-top">
                                <span class="tfl-vehicle-id">&#128642; ${t.vehicleId}</span>
                                <span class="${delayed ? 'badge-delayed' : 'badge-ontime'}">${delayed ? 'Delayed' : 'On Time'}</span>
                            </div>
                            <div class="tfl-train-detail">
                                <strong>To:</strong> ${dest}<br>
                                <strong>Next stop:</strong> ${stn}<br>
                                <strong>Arrives in:</strong> ${mins} mins (${arr})<br>
                                <strong>Location:</strong> ${t.currentLocation || 'En route'}
                            </div>
                        </div>`;
                }).join('')
            }</div>`;

        } catch (err) {
            wrap.innerHTML = `<div class="tfl-loading" style="color:#d4820a">&#9888;&#65039; Could not load live trains: ${err.message}</div>`;
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        buildMap();

        // animate cards in on page load
        const cards = document.querySelectorAll('.map-card, .info-card, .live-strip, .search-card');
        cards.forEach((card, i) => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(16px)';
            card.style.transition = `opacity 0.4s ease ${i * 0.1}s, transform 0.4s ease ${i * 0.1}s`;
            setTimeout(() => {
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
            }, 50);
        });

        // allow enter key to submit the search
        document.getElementById('trainInput').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') this.closest('form').submit();
        });

        // auto refresh TfL every 30 seconds if the map is expanded
        setInterval(() => {
            if (isExpanded) fetchLiveTrains();
        }, 30000);
    });
</script>
}