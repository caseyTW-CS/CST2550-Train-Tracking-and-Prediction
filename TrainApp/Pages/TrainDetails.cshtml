@page
@model TrainApp.Pages.TrainDetailsModel

<style>
    .details-title {
        font-family: 'Dancing Script', cursive;
        font-size: 1.8rem;
        color: #1a2f5a;
    }
    .detail-card {
        background: white;
        border-radius: 14px;
        border: 1px solid #e8f0f8;
        padding: 1.5rem;
        margin-bottom: 1rem;
    }
    .detail-label {
        font-size: 11px;
        color: #6b7c93;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 3px;
    }
    .detail-value {
        font-size: 15px;
        font-weight: 600;
        color: #1a2f5a;
    }
    .stat-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-bottom: 1rem;
    }
    .stat-box {
        background: #f0f6ff;
        border-radius: 10px;
        padding: 12px;
        text-align: center;
    }
    .stat-label {
        font-size: 11px;
        color: #6b7c93;
        margin-bottom: 4px;
    }
    .stat-value {
        font-size: 18px;
        font-weight: 700;
        color: #2d4a7a;
    }
    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: #4a7cc7;
        font-size: 14px;
        cursor: pointer;
        margin-bottom: 1.5rem;
        text-decoration: none;
        border: none;
        background: none;
        padding: 0;
    }
    .back-btn:hover { color: #2d4a7a; text-decoration: none; }
    .map-btn {
        display: block;
        width: 100%;
        padding: 14px;
        background: #2d4a7a;
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 16px;
        font-weight: 600;
        text-align: center;
        text-decoration: none;
        cursor: pointer;
        margin-top: 1.5rem;
        transition: background 0.2s;
    }
    .map-btn:hover {
        background: #1a2f5a;
        color: white;
        text-decoration: none;
    }
    .route-stop {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 0;
        border-bottom: 1px solid #f0f4f8;
    }
    .route-stop:last-child { border-bottom: none; }
    .stop-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #d0dce8;
        flex-shrink: 0;
    }
    .stop-dot.start { background: #4a7cc7; width: 13px; height: 13px; }
    .stop-dot.end { background: #28a745; width: 13px; height: 13px; }
    .stop-name {
        font-size: 14px;
        color: #2d4a7a;
        flex: 1;
    }
    .stop-badge {
        font-size: 11px;
        padding: 3px 8px;
        border-radius: 10px;
        font-weight: 500;
    }
    .badge-start { background: #e8f0ff; color: #4a7cc7; }
    .badge-end { background: #e8f8ee; color: #28a745; }
    .badge-stop { background: #f0f4f8; color: #6b7c93; }
    .train-name-badge {
        display: inline-block;
        background: #e8f0ff;
        color: #2d4a7a;
        border-radius: 20px;
        padding: 5px 14px;
        font-size: 13px;
        font-weight: 500;
        margin-bottom: 1rem;
    }
</style>

<div class="container mt-4" style="max-width:700px;">

    <!-- Back Button -->
    <a href="javascript:history.back()" class="back-btn">← Back to Results</a>

    <!-- Train Name Badge -->
    <div class="train-name-badge">🚆 @Model.TrainName</div>

    <!-- Main Info Card -->
    <div class="detail-card">

        <!-- Route -->
        <div class="mb-3">
            <div class="detail-label">Route</div>
            <div class="detail-value">@Model.Start → @Model.Destination</div>
        </div>

        <!-- Current Location & Next Station -->
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:1rem;">
            <div>
                <div class="detail-label">Current Location</div>
                <div class="detail-value" style="font-size:13px;">@Model.CurrentLocation</div>
            </div>
            <div>
                <div class="detail-label">Next Station</div>
                <div class="detail-value" style="font-size:13px;">@Model.Towards</div>
            </div>
        </div>

        <!-- Stats -->
        @if (Model.TimeToStation <= 0)
        {
            <div class="alert alert-success mb-0">
                🚆 Train is <b>at the station now</b>
            </div>
        }
        else
        {
            <div class="stat-grid">
                <div class="stat-box">
                    <div class="stat-label">Departs</div>
                    <div class="stat-value">@Model.DepartureTime</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Arrives</div>
                    <div class="stat-value">@Model.ArrivalTime</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Duration</div>
                    <div class="stat-value">@Model.DurationMinutes<span style="font-size:12px; font-weight:400;">m</span></div>
                </div>
            </div>
        }

        <!-- View Live Map Button -->
        <a href="/LiveMap" class="map-btn">View Live Map →</a>

    </div>

    <!-- Journey Route Card -->
    <div class="detail-card">
        <h6 style="color:#2d4a7a; margin-bottom:1rem;">Journey Route</h6>

        @for (int i = 0; i < Model.Route.Count; i++)
        {
            <div class="route-stop">
                <div class="stop-dot @(i == 0 ? "start" : i == Model.Route.Count - 1 ? "end" : "")"></div>
                <span class="stop-name">@Model.Route[i]</span>
                @if (i == 0)
                {
                    <span class="stop-badge badge-start">Start</span>
                }
                else if (i == Model.Route.Count - 1)
                {
                    <span class="stop-badge badge-end">Destination</span>
                }
            </div>
        }
    </div>

</div>