@page
@model TrainProject.Models.WebsitePage.Pages.AlertsModel
@{
    ViewData["Title"] = "Delay Alerts";
}

<!-- page header -->
<div class="text-center mb-4">
    <h1 class="display-4">Delay Alerts</h1>
    <p class="lead">Live disruptions and delays on the Elizabeth Line</p>
</div>

<!-- current service status -->
<div class="row justify-content-center mb-4">
    <div class="col-md-8">
        <div class="alert alert-success">
            <!-- this will eventually be dynamic based on real delay data -->
            <strong>Elizabeth Line:</strong> Good Service
        </div>
    </div>
</div>

<!-- alerts table -->
<div class="row justify-content-center">
    <div class="col-md-10">
        <h3 class="mb-3">Active Disruptions</h3>
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Reason</th>
                    <th>Severity</th>
                    <th>Estimated Duration</th>
                    <th>Reported At</th>
                    <th>Affected Journeys</th>
                </tr>
            </thead>
            <tbody>
                <!-- disruptions will show here when there are active delays -->
                <tr>
                    <td colspan="5" class="text-center text-muted">No active disruptions at this time</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>